# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# ── API keys (provide the key(s) for the provider(s) you use) ───────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
# GEMINI_API_KEY=AIza...
# OPENAI_API_KEY=sk-...

# ── Model selection ──────────────────────────────────────────────────────────
# Primary extraction model. Format: "<provider>/<model-name>"
# Default (fastest/cheapest for prototyping):
# EXTRACTION_MODEL=gemini/gemini-2.5-flash-lite
#
# Quality alternatives:
# EXTRACTION_MODEL=anthropic/claude-sonnet-4-6
# EXTRACTION_MODEL=anthropic/claude-haiku-4-5-20251001
# EXTRACTION_MODEL=openai/gpt-5.4-mini

# ── Fallback chain (three tiers — see ADR-001) ───────────────────────────────
# Comma-separated list tried in order when the primary returns a retryable error.
# 401 and 400 errors are never retried.
# EXTRACTION_FALLBACK_MODELS=anthropic/claude-haiku-4-5-20251001,openai/gpt-5.4-nano

# ── Model timeout ────────────────────────────────────────────────────────────
# Per-call timeout in seconds for litellm.completion().
# Vision calls with two images typically take 5–9 s on Haiku, 3–5 s on Gemini Flash-Lite.
# Default is 30 s (safe P99 guard). Lower only if you have benchmarked your setup.
# MODEL_TIMEOUT_SECONDS=30

# ── Railway deployment API key ───────────────────────────────────────────────
# When set, every POST /v1/check request must include:  X-API-Key: <value>
# Leave empty for local development (no auth enforced).
# API_KEY=your-secret-key-here

# ── Feature flags ────────────────────────────────────────────────────────────
# Set to "false" to skip audit log writes (useful during local testing)
# AUDIT_ENABLED=true
