# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# ── Required for real extraction calls ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Optional: model override ────────────────────────────────────────────────
# Default: claude-haiku-4-5-20251001  (fastest/cheapest for prototyping)
# Override for quality comparison:
# EXTRACTION_MODEL=claude-sonnet-4-6

# ── Optional: Railway deployment API key ────────────────────────────────────
# When set, every POST /v1/check request must include the header:
#   X-API-Key: <value>
# Leave empty for local development (no auth enforced).
# API_KEY=your-secret-key-here

# ── Feature flags ───────────────────────────────────────────────────────────
# Set to "false" to skip audit log writes (useful during local testing)
# AUDIT_ENABLED=true
